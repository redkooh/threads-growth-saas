# Threads Growth SaaS — Environment Variables
# Copy to .env and fill in your values

# ── Core ──
SAAS_SECRET=your-random-secret-here
SAAS_LOG_LEVEL=INFO
PORT=9101

# ── Database ──
# SAAS_DB_TYPE=sqlite (default) | postgresql
SAAS_DB_TYPE=sqlite
SAAS_DB=/home/ubuntu/saas/saas.db
# PostgreSQL (only if SAAS_DB_TYPE=postgresql):
# SAAS_DB_USER=postgres
# SAAS_DB_PASS=
# SAAS_DB_HOST=localhost
# SAAS_DB_PORT=5432
# SAAS_DB_NAME=threads_saas

# ── AI Content Generation ──
# AI_PROVIDER=openai | anthropic
AI_PROVIDER=openai
AI_API_KEY=sk-your-key-here
# AI_MODEL=gpt-4o-mini (default for openai) | claude-3-haiku-20240307 (default for anthropic)

# ── Stripe Billing ──
STRIPE_KEY=sk_live_your_stripe_secret_key
STRIPE_PRICE_STARTER=price_xxxxxxxxxxxx
STRIPE_PRICE_GROWTH=price_xxxxxxxxxxxx
STRIPE_PRICE_AGENCY=price_xxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
