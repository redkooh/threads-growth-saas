<svg xmlns="http://www.w3.org/2000/svg" width="1200" height="630" viewBox="0 0 1200 630">
  <defs>
    <linearGradient id="bg" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#0f0f13"/>
      <stop offset="50%" style="stop-color:#1a1a24"/>
      <stop offset="100%" style="stop-color:#0f0f13"/>
    </linearGradient>
    <linearGradient id="grad" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#a855f7"/>
      <stop offset="100%" style="stop-color:#ec4899"/>
    </linearGradient>
  </defs>
  <rect width="1200" height="630" fill="url(#bg)"/>
  <text x="600" y="240" text-anchor="middle" fill="url(#grad)" font-family="system-ui,sans-serif" font-weight="900" font-size="72" letter-spacing="-0.02em">Grow Your Threads</text>
  <text x="600" y="310" text-anchor="middle" fill="url(#grad)" font-family="system-ui,sans-serif" font-weight="900" font-size="72" letter-spacing="-0.02em">on Autopilot</text>
  <text x="600" y="380" text-anchor="middle" fill="#888" font-family="system-ui,sans-serif" font-weight="400" font-size="28">AI-powered content, engagement &amp; growth for Threads</text>
  <rect x="500" y="440" width="200" height="56" rx="14" fill="url(#grad)"/>
  <text x="600" y="475" text-anchor="middle" fill="white" font-family="system-ui,sans-serif" font-weight="700" font-size="22">7-Day Free Trial</text>
  <text x="600" y="560" text-anchor="middle" fill="#555" font-family="system-ui,sans-serif" font-weight="500" font-size="20">growpilotgpt.com</text>
</svg>
